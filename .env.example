PROJECT_NAME=Pumice
WORKSPACE_DIR=./workspace
OBSIDIAN_VAULT_DIR=./obsidian-vault

OLLAMA_COMMAND=ollama
OLLAMA_BASE_URL=http://localhost:11434

CLAUDE_PROVIDER=ollama
CLAUDE_COMMAND=claude
CLAUDE_MODEL=qwen3.5
CLAUDE_EXTRA_ARGS=-p

CODEX_PROVIDER=ollama
CODEX_COMMAND=codex
CODEX_MODEL=gpt-oss:20b
CODEX_EXTRA_ARGS=

GEMINI_PROVIDER=ollama
GEMINI_COMMAND=gemini
GEMINI_MODEL=qwen3.5
GEMINI_EXTRA_ARGS=

PUMICE_MOCK_RESPONSES=false
PUMICE_FAIL_FAST=false
